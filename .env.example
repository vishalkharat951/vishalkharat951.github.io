# Django
SECRET_KEY=generate-a-random-secret-key-with-python-m-django-core-management-utils-get_random_secret_key
DEBUG=False
ALLOWED_HOSTS=.example.com,www.example.com

# Database (SQLite — default, no config needed)
# DB_ENGINE=django.db.backends.sqlite3

# Database (PostgreSQL — uncomment and fill)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=ecom_prod
# DB_USER=ecom_user
# DB_PASSWORD=strong-db-password
# DB_HOST=localhost
# DB_PORT=5432
# DB_CONN_MAX_AGE=60

# Database (MySQL — uncomment and fill)
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=ecom_prod
# DB_USER=ecom_user
# DB_PASSWORD=strong-db-password
# DB_HOST=localhost
# DB_PORT=3306

# Security
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# PhonePe Payment Gateway
PHONEPE_MERCHANT_ID=your-merchant-id
PHONEPE_SALT_KEY=your-salt-key
PHONEPE_SALT_INDEX=1
PHONEPE_CALLBACK_URL=https://www.example.com/payments/callback/
PHONEPE_ENVIRONMENT=production

# Email (for error reports)
# ADMINS=Admin Name <admin@example.com>
# SERVER_EMAIL=server@example.com
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=user@example.com
# EMAIL_HOST_PASSWORD=strong-email-password
# EMAIL_USE_TLS=True
